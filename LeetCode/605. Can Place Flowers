bool canPlaceFlowers(int* flowerbed, int flowerbedSize, int n) {

    for (int i = 0; i < flowerbedSize; i++) {

        //A condição de plantar
        if (flowerbed[i] == 0 && // <-A posição atual está vazia
            (i == 0 || flowerbed[i-1] == 0) && // <- esquerta vazia
            (i == flowerbedSize-1 || flowerbed[i+1] == 0)) { // <- direita vazia

            //entao planta
            flowerbed[i] = 1;
            n--;
        }
    }
    return n <= 0;
}
